    private void updateActionPerformed(java.awt.event.ActionEvent evt) {

        String inventoryIdText =
                inventoryID.getText().trim();

        String newMaterial =
                material.getText().trim();

        String stockText =
                stoqua.getText().trim();

        String costText =
                matcost.getText().trim();

        if (inventoryIdText.isEmpty()
                || newMaterial.isEmpty()
                || stockText.isEmpty()
                || costText.isEmpty()) {

            JOptionPane.showMessageDialog(
                    this,
                    "Please fill in all fields.");

            return;
        }

        try {

            int inventoryId =
                    Integer.parseInt(inventoryIdText);

            int stockQty =
                    Integer.parseInt(stockText);

            double materialCost =
                    Double.parseDouble(costText);

            if (stockQty < 0
                    || materialCost < 0) {

                JOptionPane.showMessageDialog(
                        this,
                        "Stock quantity and material cost cannot be negative.");

                return;
            }

            Connection conn =
                    getConnection();

            String updateSql =
                    "UPDATE dbo.Inventory "
                    + "SET material = ?, "
                    + "stock_quantity = ?, "
                    + "material_cost = ? "
                    + "WHERE inventory_id = ?";

            PreparedStatement pst =
                    conn.prepareStatement(updateSql);

            pst.setString(1, newMaterial);
            pst.setInt(2, stockQty);
            pst.setDouble(3, materialCost);
            pst.setInt(4, inventoryId);

            int rows =
                    pst.executeUpdate();

            if (rows > 0) {

                JOptionPane.showMessageDialog(
                        this,
                        "Inventory updated successfully.");

            } else {

                JOptionPane.showMessageDialog(
                        this,
                        "Update failed.");
            }

            pst.close();
            conn.close();

        } catch (NumberFormatException ex) {

            JOptionPane.showMessageDialog(
                    this,
                    "Inventory ID and stock quantity must be whole numbers.\n"
                    + "Material cost must be a number.");

        } catch (Exception ex) {

            JOptionPane.showMessageDialog(
                    this,
                    "Error: "
                    + ex.getMessage());
        }
    }

    private void saveActionPerformed(java.awt.event.ActionEvent evt) {

        String materialName =
                material.getText().trim();

        String stockText =
                stoqua.getText().trim();

        String costText =
                matcost.getText().trim();

        if (materialName.isEmpty()
                || stockText.isEmpty()
                || costText.isEmpty()) {

            JOptionPane.showMessageDialog(
                    this,
                    "Please fill in all fields.");

            return;
        }

        try {

            int stockQuantity =
                    Integer.parseInt(stockText);

            double materialCost =
                    Double.parseDouble(costText);

            if (stockQuantity < 0
                    || materialCost < 0) {

                JOptionPane.showMessageDialog(
                        this,
                        "Stock quantity and cost cannot be negative.");

                return;
            }

            String message =
                    "Are you sure you want to save this inventory record?\n\n"
                    + "Inventory Information:\n"
                    + "Material: " + materialName + "\n"
                    + "Stock Quantity: " + stockQuantity + "\n"
                    + "Material Cost: " + materialCost;

            int confirm =
                    JOptionPane.showConfirmDialog(
                            this,
                            message,
                            "Confirm Save",
                            JOptionPane.YES_NO_OPTION
                    );

            if (confirm != JOptionPane.YES_OPTION) {

                return;
            }

            String sql =
                    "INSERT INTO dbo.Inventory "
                    + "(material, stock_quantity, material_cost) "
                    + "VALUES (?, ?, ?)";

            Connection conn =
                    getConnection();

            PreparedStatement pst =
                    conn.prepareStatement(sql);

            pst.setString(1, materialName);
            pst.setInt(2, stockQuantity);
            pst.setDouble(3, materialCost);

            pst.executeUpdate();

            JOptionPane.showMessageDialog(
                    this,
                    "Inventory saved successfully.");

            material.setText("");
            stoqua.setText("");
            matcost.setText("");

            generateInventoryId();

            pst.close();
            conn.close();

        } catch (NumberFormatException ex) {

            JOptionPane.showMessageDialog(
                    this,
                    "Stock quantity must be a whole number and material cost must be a number.");

        } catch (java.sql.SQLException ex) {

            JOptionPane.showMessageDialog(
                    this,
                    "Error: "
                    + ex.getMessage());

        } catch (Exception ex) {

            JOptionPane.showMessageDialog(
                    this,
                    "Error: "
                    + ex.getMessage());
        }
    }

    private void generateInventoryId() {

        String sql =
                "SELECT ISNULL(MAX(inventory_id), 5999) + 1 AS next_id "
                + "FROM dbo.Inventory";

        try {

            PreparedStatement pst =
                    conn.prepareStatement(sql);

            java.sql.ResultSet rs =
                    pst.executeQuery();

            if (rs.next()) {

                inventoryID.setText(
                        String.valueOf(
                                rs.getInt("next_id"))
                );

                inventoryID.setEditable(true);
                inventoryID.setFocusable(true);
            }

            rs.close();
            pst.close();

        } catch (java.sql.SQLException ex) {

            JOptionPane.showMessageDialog(
                    this,
                    "Error generating Inventory ID: "
                    + ex.getMessage());
        }
    }

