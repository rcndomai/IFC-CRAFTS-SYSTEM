    private void generateProductId() {

        String sql =
            "SELECT ISNULL(MAX(product_id), 1999) + 1 AS next_id FROM dbo.Products";

        try {
            PreparedStatement pst = conn.prepareStatement(sql);
            java.sql.ResultSet rs = pst.executeQuery();

            if (rs.next()) {
                productID.setText(
                        String.valueOf(rs.getInt("next_id"))
                );

                productID.setEditable(true);
                productID.setFocusable(true);
            }

            rs.close();
            pst.close();

        } catch (java.sql.SQLException ex) {
            JOptionPane.showMessageDialog(this,
                    "Error generating Product ID: " + ex.getMessage());
        }
    }
