    private void saveActionPerformed(java.awt.event.ActionEvent evt) {                                     
        String name = customername.getText().trim();
        String address = customeraddress.getText().trim();
        String contact = contactnum.getText().trim();

        if (name.isEmpty() || address.isEmpty() || contact.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Please fill in all fields.");
            return;
        }

        if (!contact.matches("\\d{11}")) {
            JOptionPane.showMessageDialog(this, "Contact number must be exactly 11 digits.");
            contactnum.requestFocus();
            return;
        }

        String message = "Are you sure you want to save this customer record?\n\n"
                + "Customer Information:\n"
                + "Customer ID: " + customerID.getText().trim() + "\n"
                + "Name: " + name + "\n"
                + "Address: " + address + "\n"
                + "Contact Number: " + contact;

        int confirm = JOptionPane.showConfirmDialog(
                this,
                message,
                "Confirm Save",
                JOptionPane.YES_NO_OPTION
        );

        if (confirm != JOptionPane.YES_OPTION) {
            return;
        }

        try {
            String sql = "INSERT INTO dbo.Customers "
                    + "(customer_name, customer_address, contact_num) "
                    + "VALUES (?, ?, ?)";

            PreparedStatement pst = conn.prepareStatement(sql);

            pst.setString(1, name);
            pst.setString(2, address);
            pst.setString(3, contact);

            pst.executeUpdate();
            pst.close();

            JOptionPane.showMessageDialog(this, "Customer saved successfully.");

            customername.setText("");
            customeraddress.setText("");
            contactnum.setText("");
            generateCustomerId();

        } catch (java.sql.SQLException ex) {
            JOptionPane.showMessageDialog(this, "Error: " + ex.getMessage());
        } catch (Exception ex) {
            JOptionPane.showMessageDialog(this, "Error: " + ex.getMessage());
        }
    }                                    

