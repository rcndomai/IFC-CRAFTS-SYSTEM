    private void deleteActionPerformed(java.awt.event.ActionEvent evt) {                                       
        String idText = customerID.getText().trim();

        if (idText.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Enter customer ID first.");
            customerID.requestFocus();
            return;
        }

        try {
            int customerId = Integer.parseInt(idText);

            Connection conn = getConnection();

            String selectSql = "SELECT customer_name, customer_address, contact_num FROM dbo.Customers WHERE customer_id = ?";
            PreparedStatement selectPst = conn.prepareStatement(selectSql);
            selectPst.setInt(1, customerId);

            java.sql.ResultSet rs = selectPst.executeQuery();

            if (!rs.next()) {
                JOptionPane.showMessageDialog(this, "Customer ID not found.");
                rs.close();
                selectPst.close();
                conn.close();
                return;
            }

            String currentName = rs.getString("customer_name");
            String currentAddress = rs.getString("customer_address");
            String currentContact = rs.getString("contact_num");

            rs.close();
            selectPst.close();

            String message = "Are you sure you want to delete this customer record?\n\n"
                    + "Customer Information:\n"
                    + "Customer ID: " + customerId + "\n"
                    + "Name: " + currentName + "\n"
                    + "Address: " + currentAddress + "\n"
                    + "Contact Number: " + currentContact;

            int confirm = JOptionPane.showConfirmDialog(
                    this,
                    message,
                    "Confirm Delete",
                    JOptionPane.YES_NO_OPTION
            );

            if (confirm != JOptionPane.YES_OPTION) {
                conn.close();
                return;
            }

            String deleteSql = "DELETE FROM dbo.Customers WHERE customer_id = ?";
            PreparedStatement deletePst = conn.prepareStatement(deleteSql);
            deletePst.setInt(1, customerId);

            int rows = deletePst.executeUpdate();

            if (rows > 0) {
                JOptionPane.showMessageDialog(this, "Customer deleted successfully.");
            } else {
                JOptionPane.showMessageDialog(this, "Delete failed.");
            }

            deletePst.close();
            conn.close();

        } catch (NumberFormatException ex) {
            JOptionPane.showMessageDialog(this, "Customer ID must be a number.");
        } catch (java.sql.SQLException ex) {
            JOptionPane.showMessageDialog(this, "Error deleting record: " + ex.getMessage());
        } catch (Exception ex) {
            JOptionPane.showMessageDialog(this, "Error: " + ex.getMessage());
        }
    }                                      

