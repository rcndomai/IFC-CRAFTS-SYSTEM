    private void saveActionPerformed(java.awt.event.ActionEvent evt) {                                     
        String name = productname.getText().trim();
        String type = producttype.getText().trim();
        String priceText = price.getText().trim();
        String stockText = stocks.getText().trim();

        if (name.isEmpty() || type.isEmpty() || priceText.isEmpty() || stockText.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Please fill in all fields.");
            return;
        }

        try {
            double unitPrice = Double.parseDouble(priceText);
            int productStock = Integer.parseInt(stockText);

            if (unitPrice < 0 || productStock < 0) {
                JOptionPane.showMessageDialog(this, "Unit price and stock cannot be negative.");
                return;
            }

            String message = "Are you sure you want to save this product record?\n\n"
                + "Product Information:\n"
                + "Product Name: " + name + "\n"
                + "Product Type: " + type + "\n"
                + "Unit Price: " + priceText + "\n"
                + "Stock: " + productStock;

            int confirm = JOptionPane.showConfirmDialog(
                    this,
                    message,
                    "Confirm Save",
                    JOptionPane.YES_NO_OPTION
            );

            if (confirm != JOptionPane.YES_OPTION) {
                return;
            }

            String sql = "INSERT INTO dbo.Products (product_name, product_type, unit_price, stock) VALUES (?, ?, ?, ?)";
            Connection conn = getConnection();
            PreparedStatement pst = conn.prepareStatement(sql);

            int productId = Integer.parseInt(productID.getText());

            pst.setString(1, name);
            pst.setString(2, type);
            pst.setDouble(3, unitPrice);
            pst.setInt(4, productStock);

            pst.executeUpdate();

            JOptionPane.showMessageDialog(this, "Product saved successfully.");

            productname.setText("");
            price.setText("");
            stocks.setText("");
            producttype.setText("");

            generateProductId();

            pst.close();
            conn.close();

        } catch (NumberFormatException ex) {
            JOptionPane.showMessageDialog(this, "Unit price must be a number and stock must be a whole number.");
        } catch (java.sql.SQLException ex) {
            JOptionPane.showMessageDialog(this, "Error: " + ex.getMessage());
        } catch (Exception ex) {
            JOptionPane.showMessageDialog(this, "Error: " + ex.getMessage());
        }
    }                                    

