    private void deleteActionPerformed(java.awt.event.ActionEvent evt) {                                       
        String idText = productID.getText().trim();

        if (idText.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Enter product ID first.");
            productID.requestFocus();
            return;
        }

        try {
            int productId = Integer.parseInt(idText);

            Connection conn = getConnection();

            String selectSql = "SELECT product_name, product_type, unit_price, stock FROM dbo.Products WHERE product_id = ?";
            PreparedStatement selectPst = conn.prepareStatement(selectSql);
            selectPst.setInt(1, productId);

            java.sql.ResultSet rs = selectPst.executeQuery();

            if (!rs.next()) {
                JOptionPane.showMessageDialog(this, "Product ID not found.");
                rs.close();
                selectPst.close();
                conn.close();
                return;
            }

            String currentName = rs.getString("product_name");
            String currentType = rs.getString("product_type");
            double currentPrice = rs.getDouble("unit_price");
            int currentStock = rs.getInt("stock");

            rs.close();
            selectPst.close();

            String message = "Are you sure you want to delete this product record?\n\n"
                    + "Product Information:\n"
                    + "Product ID: " + productId + "\n"
                    + "Product Name: " + currentName + "\n"
                    + "Product Type: " + currentType + "\n"
                    + "Unit Price: " + currentPrice + "\n"
                    + "Stock: " + currentStock;

            int confirm = JOptionPane.showConfirmDialog(
                    this,
                    message,
                    "Confirm Delete",
                    JOptionPane.YES_NO_OPTION
            );

            if (confirm != JOptionPane.YES_OPTION) {
                conn.close();
                return;
            }

            String deleteSql = "DELETE FROM dbo.Products WHERE product_id = ?";
            PreparedStatement deletePst = conn.prepareStatement(deleteSql);
            deletePst.setInt(1, productId);

            int rows = deletePst.executeUpdate();

            if (rows > 0) {
                JOptionPane.showMessageDialog(this, "Product deleted successfully.");
            } else {
                JOptionPane.showMessageDialog(this, "Delete failed.");
            }

            deletePst.close();
            conn.close();

        } catch (NumberFormatException ex) {
            JOptionPane.showMessageDialog(this, "Product ID must be a number.");
        } catch (java.sql.SQLException ex) {
            JOptionPane.showMessageDialog(this, "Error deleting record: " + ex.getMessage());
        } catch (Exception ex) {
            JOptionPane.showMessageDialog(this, "Error: " + ex.getMessage());
        }
    }                                      

