    private void generateCustomerId() {

        String sql = "SELECT ISNULL(MAX(customer_id), 999) + 1 AS next_id FROM dbo.Customers";

    try {
        PreparedStatement pst = conn.prepareStatement(sql);
        ResultSet rs = pst.executeQuery();

        if (rs.next()) {
            customerID.setText(String.valueOf(rs.getInt("next_id")));
            customerID.setEditable(true);
            customerID.setFocusable(true);
        }

        rs.close();
        pst.close();

    } catch (SQLException ex) {
        JOptionPane.showMessageDialog(this, "Error generating Customer ID: " + ex.getMessage());
    }
}
    
