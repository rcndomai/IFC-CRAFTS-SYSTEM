//save
String name = customername.getText().trim();
        String address = customeraddress.getText().trim();
        String contact = contactnum.getText().trim();

        if (name.isEmpty() || address.isEmpty() || contact.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Please fill in all fields.");
            return;
        }

        if (!contact.matches("\\d{11}")) {
            JOptionPane.showMessageDialog(this, "Contact number must be exactly 11 digits.");
            contactnum.requestFocus();
            return;
        }

        String message = "Are you sure you want to save this customer record?\n\n"
                + "Customer Information:\n"
                + "Name: " + name + "\n"
                + "Address: " + address + "\n"
                + "Contact Number: " + contact;

        int confirm = JOptionPane.showConfirmDialog(
                this,
                message,
                "Confirm Save",
                JOptionPane.YES_NO_OPTION
        );

        if (confirm != JOptionPane.YES_OPTION) {
            return;
        }

        try {
            String sql = "INSERT INTO dbo.Customers (customer_name, customer_address, contact_num) VALUES (?, ?, ?)";

            Connection conn = getConnection();
            PreparedStatement pst = conn.prepareStatement(sql);

            pst.setString(1, name);
            pst.setString(2, address);
            pst.setString(3, contact);

            pst.executeUpdate();

            JOptionPane.showMessageDialog(this, "Customer saved successfully.");

            pst.close();
            conn.close();

        } catch (java.sql.SQLException ex) {
            JOptionPane.showMessageDialog(this, "Error: " + ex.getMessage());
        } catch (Exception ex) {
            JOptionPane.showMessageDialog(this, "Error: " + ex.getMessage());
        }
    }         



// upd
String idText = customerID.getText().trim();
        String newName = customername.getText().trim();
        String newAddress = customeraddress.getText().trim();
        String newContact = contactnum.getText().trim();

        if (idText.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Enter customer ID first.");
            customerID.requestFocus();
            return;
        }

        if (newName.isEmpty() || newAddress.isEmpty() || newContact.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Name, address, and contact number cannot be empty.");
            return;
        }

        try {
            int customerId = Integer.parseInt(idText);

            Connection conn = getConnection();

            String selectSql = "SELECT customer_name, customer_address, contact_num FROM dbo.Customers WHERE customer_id = ?";
            PreparedStatement selectPst = conn.prepareStatement(selectSql);
            selectPst.setInt(1, customerId);

            java.sql.ResultSet rs = selectPst.executeQuery();

            if (!rs.next()) {
                JOptionPane.showMessageDialog(this, "Customer ID not found.");
                rs.close();
                selectPst.close();
                conn.close();
                return;
            }

            String currentName = rs.getString("customer_name");
            String currentAddress = rs.getString("customer_address");
            String currentContact = rs.getString("contact_num");

            rs.close();
            selectPst.close();

            String message = "Are you sure you want to update this customer record?\n\n"
                    + "Current Information:\n"
                    + "Customer ID: " + customerId + "\n"
                    + "Name: " + currentName + "\n"
                    + "Address: " + currentAddress + "\n"
                    + "Contact Number: " + currentContact + "\n\n"
                    + "New Information:\n"
                    + "Customer ID: " + customerId + "\n"
                    + "Name: " + newName + "\n"
                    + "Address: " + newAddress + "\n"
                    + "Contact Number: " + newContact;

            int confirm = JOptionPane.showConfirmDialog(
                    this,
                    message,
                    "Confirm Update",
                    JOptionPane.YES_NO_OPTION
            );

            if (confirm != JOptionPane.YES_OPTION) {
                conn.close();
                return;
            }

            String updateSql = "UPDATE dbo.Customers SET customer_name = ?, customer_address = ?, contact_num = ? WHERE customer_id = ?";
            PreparedStatement updatePst = conn.prepareStatement(updateSql);

            updatePst.setString(1, newName);
            updatePst.setString(2, newAddress);
            updatePst.setString(3, newContact);
            updatePst.setInt(4, customerId);

            int rows = updatePst.executeUpdate();

            if (rows > 0) {
                JOptionPane.showMessageDialog(this, "Customer record updated successfully.");
            } else {
                JOptionPane.showMessageDialog(this, "Update failed.");
            }

            updatePst.close();
            conn.close();

        } catch (NumberFormatException ex) {
            JOptionPane.showMessageDialog(this, "Customer ID must be a number.");
        } catch (java.sql.SQLException ex) {
            JOptionPane.showMessageDialog(this, "Error updating record: " + ex.getMessage());
        } catch (Exception ex) {
            JOptionPane.showMessageDialog(this, "Error: " + ex.getMessage());
        }
    }      




