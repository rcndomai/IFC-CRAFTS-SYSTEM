            JOptionPane.YES_NO_OPTION);

        if (response == JOptionPane.YES_OPTION) {
            clearFields();
            JOptionPane.showMessageDialog(this, "Fields cleared successfully.");
        }
    }                                     

    private void clearFields() {
        afiliatename.setText("");
        socmedacc.setText("");
        startdate.setDate(null);
        enddate.setDate(null);
        affiliatestatus.setSelectedIndex(-1);
        generateAffiliateId(); 
    }
    
    private void saveActionPerformed(java.awt.event.ActionEvent evt) {                                     
        String inputId = affiliateID.getText().trim();
        String name = afiliatename.getText().trim();
        java.util.Date sDate = startdate.getDate();
        java.util.Date eDate = enddate.getDate();
        Object statusObj = affiliatestatus.getSelectedItem();
        String status = (statusObj != null) ? statusObj.toString() : "";
        String social = socmedacc.getText().trim();

        if (inputId.isEmpty() || name.isEmpty() || sDate == null || status.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Please fill in all required fields (ID, Name, Start Date, Status).");
            return;
        }

        String message = "Are you sure you want to save this affiliate record?\n\n"
                + "Affiliate Information:\n"
                + "Affiliate ID: " + inputId + "\n"
                + "Name: " + name + "\n"
                + "Start Date: " + sDate + "\n"
                + "Status: " + status;

        int confirm = JOptionPane.showConfirmDialog(this, message, "Confirm Save", JOptionPane.YES_NO_OPTION);
        if (confirm != JOptionPane.YES_OPTION) {
            return;
        }

        try {
            String checkSql = "SELECT COUNT(*) FROM dbo.Affiliates WHERE affiliate_id = ?";
            try (PreparedStatement checkPst = conn.prepareStatement(checkSql)) {
                checkPst.setString(1, inputId);
                try (ResultSet rs = checkPst.executeQuery()) {
                    if (rs.next() && rs.getInt(1) > 0) {
                        JOptionPane.showMessageDialog(this, "The ID '" + inputId + "' is already assigned! Choose a distinct ID.", "Duplicate Found", JOptionPane.WARNING_MESSAGE);
                        affiliateID.requestFocus();
                        return;
                    }
                }
            }

            String sql = "INSERT INTO dbo.Affiliates (affiliate_id, aff_name, start_date, end_date, aff_status, soc_med_acc) "
                       + "VALUES (?, ?, ?, ?, ?, ?)";

            try (PreparedStatement pst = conn.prepareStatement(sql)) {
                pst.setString(1, inputId);
                pst.setString(2, name);
                pst.setDate(3, new java.sql.Date(sDate.getTime()));
                if (eDate != null) {
                    pst.setDate(4, new java.sql.Date(eDate.getTime()));
                } else {
                    pst.setNull(4, java.sql.Types.DATE);
                }
                pst.setString(5, status);
                pst.setString(6, social);

                pst.executeUpdate();
                JOptionPane.showMessageDialog(this, "Affiliate saved successfully.");

                clearFields();
            }

        } catch (SQLException ex) {
            JOptionPane.showMessageDialog(this, "Database Error: " + ex.getMessage());
        } catch (Exception ex) {
            JOptionPane.showMessageDialog(this, "Error: " + ex.getMessage());
        }
    }                                    

