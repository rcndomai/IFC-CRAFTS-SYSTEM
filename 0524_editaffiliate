    private void generateAffiliateId() {
        String sql = "SELECT ISNULL(MAX(CAST(affiliate_id AS INT)), 7999) + 1 AS next_id "
                + "FROM dbo.Affiliates "
                + "WHERE ISNUMERIC(affiliate_id) = 1";

        try {
            PreparedStatement pst = conn.prepareStatement(sql);
            ResultSet rs = pst.executeQuery();

            if (rs.next()) {
                affiliateID.setText(String.valueOf(rs.getInt("next_id")));
                
                // FIXED HERE: Changed from false to true to match your editcustomer pattern!
                affiliateID.setEditable(true);
                affiliateID.setFocusable(true);
            }

            rs.close();
            pst.close();

        } catch (SQLException ex) {
            JOptionPane.showMessageDialog(this, "Error generating Affiliate ID: " + ex.getMessage());
        }
    }

    

