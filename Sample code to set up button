package ClinicReservationSystem.UIPage;


import java.awt.*;
import java.awt.event.ActionListener;
import javax.swing.*;

public class HomePageButton extends JButton {
    
    public HomePageButton(String imagePath) {
        ImageIcon icon = new ImageIcon(imagePath);
        Image scaledImg = icon.getImage().getScaledInstance(120, 120, Image.SCALE_SMOOTH); // size ng icons
        ImageIcon scaledIcon = new ImageIcon(scaledImg);

        setIcon(scaledIcon);

        setHorizontalTextPosition(SwingConstants.CENTER); // sets where the text will be positioned
        setVerticalTextPosition(SwingConstants.BOTTOM);

        setContentAreaFilled(false); // makes button transparent
        setFocusPainted(false); // mawawala yung blue something sa gilid ng buttons
        setOpaque(false);
        setBorder(BorderFactory.createLineBorder(Color.DARK_GRAY, 3, true)); // border ng button
    }

    // what the button will do when clicked
    public HomePageButton onClick(ActionListener listener) {
        this.addActionListener(listener);
        return this;
    }
    
}
