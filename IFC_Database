/* GENERATED BY DEFAULT AS IDENTITY for creating initial values in AUTO_INCREMENT 
    primary key ng kada table has different starting numbers. Their starting
    numbers are based on kung pang ilan sila nag appear sa buttons sa home page.*/

CREATE TABLE Customers (
	customer_id INT GENERATED BY DEFAULT AS IDENTITY (START WITH 1000) PRIMARY KEY,
	customer_name VARCHAR(50) NOT NULL,
	customer_address VARCHAR(255) NOT NULL,
	contact_num VARCHAR(11) UNIQUE NOT NULL
); 

CREATE TABLE Affiliates (
	affiliate_id VARCHAR(30) PRIMARY KEY, /* unique promo code for affiliates */
	aff_name VARCHAR(100) NOT NULL,
	start_date DATE NOT NULL,
	end_date DATE GENERATED ALWAYS AS ((start_date + 30)::DATE) STORED,
	aff_status VARCHAR(30) NOT NULL,
	soc_med_acc VARCHAR(100)
);

CREATE TABLE Products (
	product_id INT GENERATED BY DEFAULT AS IDENTITY (START WITH 2000) PRIMARY KEY, 
	product_name VARCHAR(100) UNIQUE NOT NULL,
	product_type VARCHAR(50) NOT NULL,
	unit_price DECIMAL(10,2) NOT NULL CHECK (unit_price >= 0), 
	stock INT NOT NULL CHECK (stock >= 0)
);

CREATE TABLE Orders (
	order_id INT GENERATED BY DEFAULT AS IDENTITY (START WITH 3000) PRIMARY KEY,
	order_date DATE NOT NULL, 
	due_date DATE NOT NULL CHECK (due_date >= order_date), 
	order_status VARCHAR(30) NOT NULL, 
	customer_id INT NOT NULL,
	affiliate_id VARCHAR(30),
	total_amount DECIMAL(10,2) NOT NULL DEFAULT 0,
	CONSTRAINT fk_customer_id_orders FOREIGN KEY (customer_id)
    	REFERENCES customers(customer_id),
	CONSTRAINT fk_affiliate_id_orders FOREIGN KEY (affiliate_id)
    	REFERENCES affiliates(affiliate_id)	
);

CREATE TABLE Order_Items (
	order_id INT NOT NULL,
	product_id INT NOT NULL,
	quantity INT NOT NULL CHECK (quantity > 0),
	price_at_order DECIMAL(10,2) NOT NULL CHECK (price_at_order >= 0),
	PRIMARY KEY (order_id, product_id),
	CONSTRAINT fk_order_id_orderitem FOREIGN KEY (order_id)
    	REFERENCES orders(order_id),
	CONSTRAINT fk_product_id_orderitem FOREIGN KEY (product_id)
    	REFERENCES products(product_id)
);

CREATE OR REPLACE FUNCTION set_price_at_order()
RETURNS TRIGGER AS $$
BEGIN
    -- Only auto-fill if user did not manually provide value
    IF NEW.price_at_order IS NULL OR NEW.price_at_order = 0 THEN

        SELECT NEW.quantity * p.unit_price
        INTO NEW.price_at_order
        FROM Products p
        WHERE p.product_id = NEW.product_id;
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_set_price_at_order
BEFORE INSERT OR UPDATE
ON Order_Items
FOR EACH ROW
EXECUTE FUNCTION set_price_at_order();

CREATE OR REPLACE FUNCTION update_order_total()
RETURNS TRIGGER AS $$
BEGIN
    UPDATE Orders
    SET total_amount = (
        SELECT COALESCE(SUM(price_at_order), 0)
        FROM Order_Items
        WHERE order_id = COALESCE(NEW.order_id, OLD.order_id)
    )
    WHERE order_id = COALESCE(NEW.order_id, OLD.order_id);

    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_update_order_total
AFTER INSERT OR UPDATE OR DELETE
ON Order_Items
FOR EACH ROW
EXECUTE FUNCTION update_order_total();

CREATE TABLE Payments (
	payment_id INT GENERATED BY DEFAULT AS IDENTITY (START WITH 4000) PRIMARY KEY,	
	order_id INT NOT NULL,
	payment_status VARCHAR(30) NOT NULL,
	date_paid DATE,
	payment_method VARCHAR(30) NOT NULL,
	amount DECIMAL(10,2) NOT NULL CHECK (amount >= 0), 
	CONSTRAINT fk_order_id_payments FOREIGN KEY (order_id)
    	REFERENCES orders(order_id)
);

CREATE TABLE Shipments (
	shipment_id INT GENERATED BY DEFAULT AS IDENTITY (START WITH 5000) PRIMARY KEY,
	order_id INT NOT NULL,
	shipment_date DATE, 
	delivery_mode VARCHAR(30) NOT NULL,
	courier VARCHAR(50),
	shipment_status VARCHAR(30) NOT NULL,
	CONSTRAINT fk_order_id_shipments FOREIGN KEY (order_id)
    	REFERENCES orders(order_id)
);

/* I was thinking na maglagay tayo ng price per material cuz ito sana yung pagkukuhaan natin 
	ng expenses na ibabawas sa sales to get the profit. What do you guys think? */
CREATE TABLE Inventory (  
	inventory_id INT GENERATED BY DEFAULT AS IDENTITY (START WITH 6000) PRIMARY KEY,
	material VARCHAR(100) UNIQUE NOT NULL,
	unit INT NOT NULL CHECK (unit >= 0)  
);
